# =====================================================================
# Edu-Nexus BE — Production environment template
# =====================================================================
# Copy file này thành `.env` trên server (/opt/edu-nexus/.env) và điền giá trị thật.
# KHÔNG commit file `.env` lên git.
#
#   cp .env.example .env && nano .env
# =====================================================================

# ---------- Image ----------
# Tag image trên GHCR. CI/CD sẽ override bằng commit SHA khi deploy.
API_IMAGE=ghcr.io/edu-nexus-exe/be:latest

# Domain trỏ về VPS để Caddy cấp SSL
API_DOMAIN=api.yourdomain.com

# ---------- Database ----------
POSTGRES_DB=
POSTGRES_USER=postgres
# !!! ĐỔI password mạnh trước khi deploy. KHÔNG dùng default này trên prod.
POSTGRES_PASSWORD=CHANGE_ME_strong_random_pw

# ---------- JWT ----------
# Sinh key dài ngẫu nhiên: `openssl rand -base64 64`
JWT_KEY=CHANGE_ME_long_random_secret_at_least_64_chars
JWT_ISSUER=
JWT_AUDIENCE=
JWT_ACCESS_MIN=15
JWT_REFRESH_DAYS=30

# ---------- Google OAuth ----------
GOOGLE_CLIENT_ID=

# ---------- AI / OpenAI ----------
# Sprint 1 mặc định false. Bật khi đã có OpenAI key.
AI_ENABLED=false
OPENAI_API_KEY=
